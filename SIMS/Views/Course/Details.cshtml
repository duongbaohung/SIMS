@model SIMS.DatabaseContext.Entities.Course

@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewData["Title"] = "Course Details";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card bg-dark text-light border-secondary shadow">
                <div class="card-header border-secondary bg-dark d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle me-2 text-info"></i>
                        Details for @Model.CourseCode
                    </h5>
                    <span class="badge @(Model.Status == 1 ? "bg-success" : "bg-danger") px-3 py-2">
                        @(Model.Status == 1 ? "OPEN" : "CLOSED")
                    </span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h2 class="display-6 fw-bold mb-1">@Model.CourseName</h2>
                            <p class="text-secondary mb-0">Full Catalog Registration Record</p>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <div class="h4 mb-0 text-primary fw-bold">@Model.Credits Credits</div>
                            <small class="text-muted">Standard Academic Units</small>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="p-3 border border-secondary rounded bg-black bg-opacity-25">
                                <div class="small text-secondary text-uppercase mb-1">Course Code</div>
                                <div class="h5 mb-0 fw-bold">@Model.CourseCode</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border border-secondary rounded bg-black bg-opacity-25">
                                <div class="small text-secondary text-uppercase mb-1">Total Capacity</div>
                                <div class="h5 mb-0 fw-bold">@Model.Capacity Seats</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border border-secondary rounded bg-black bg-opacity-25">
                                <div class="small text-secondary text-uppercase mb-1">Enrollment Date</div>
                                <div class="h5 mb-0">@Model.CreatedAt?.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="small text-secondary text-uppercase fw-bold mb-2 d-block">Enrollment Progress</label>
                        <div class="progress" style="height: 25px; background-color: rgba(255,255,255,0.05);">
                            @{
                                var percent = Model.Capacity > 0 ? (double)Model.Enrolled / Model.Capacity * 100 : 0;
                            }
                            <div class="progress-bar progress-bar-striped progress-bar-animated @(percent > 90 ? "bg-danger" : "bg-success")"
                                 role="progressbar" style="width: @percent%">
                                @Model.Enrolled / @Model.Capacity (@percent.ToString("F1")%)
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between border-top border-secondary pt-4 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-chevron-left me-2"></i>Back to Catalog
                        </a>
                        <div class="btn-group">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-courseCode="@Model.CourseCode" class="btn btn-info text-dark">
                                    <i class="fas fa-edit me-2"></i>Edit Course
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>