@model SIMS.DatabaseContext.Entities.Course
@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewData["title"] = "Courses";
    ViewData["breadcrumb"] = "Create new Course";
    ViewData["breadcrumb-item"] = "Courses";
}

<div class="row">
    <div class="col-lg-8">
        <div class="card bg-dark text-light border-secondary mb-4">
            <div class="card-header border-secondary">
                <i class="fas fa-plus-square me-1"></i>
                Course Details
            </div>
            <div class="card-body">
                <form asp-action="Add" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="CourseCode" class="form-label">Course Code</label>
                            <input asp-for="CourseCode" class="form-control bg-dark text-light border-secondary" required placeholder="e.g., CS101" />
                        </div>
                        <div class="col-md-8 mb-3">
                            <label asp-for="CourseName" class="form-label">Course Name</label>
                            <input asp-for="CourseName" class="form-control bg-dark text-light border-secondary" required placeholder="e.g., Intro to Programming" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control bg-dark text-light border-secondary" rows="3" placeholder="Brief overview of the course..."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Credits" class="form-label">Credits</label>
                            <input asp-for="Credits" type="number" min="1" max="6" class="form-control bg-dark text-light border-secondary" required placeholder="3" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Capacity" class="form-label">Max Capacity</label>
                            <input asp-for="Capacity" type="number" min="1" class="form-control bg-dark text-light border-secondary" required placeholder="30" />
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> Save Course</button>
                        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>