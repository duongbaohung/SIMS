@model SIMS.Models.EnrollmentViewModel

@{
    ViewData["Title"] = "Assign Student to Course";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Course Assignment</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Course")">Courses</a></li>
        <li class="breadcrumb-item active">Assign Student</li>
    </ol>

    <div class="row">
        <div class="col-xl-6">
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-dark text-light border-secondary">
                    <i class="fas fa-user-plus me-1 text-primary"></i>
                    Enrollment Form
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Assign" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label fw-bold small text-secondary">SELECT STUDENT (USERNAME)</label>
                            <select asp-for="StudentId" class="form-select border-secondary"
                                    asp-items="@(new SelectList(Model.Students, "Id", "FullName"))">
                                <option value="">-- Choose a Student --</option>
                            </select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CourseId" class="form-label fw-bold small text-secondary">SELECT COURSE (NAME)</label>
                            <select asp-for="CourseId" class="form-select border-secondary"
                                    asp-items="@(new SelectList(Model.Courses, "Id", "Title"))">
                                <option value="">-- Choose a Course --</option>
                            </select>
                            <span asp-validation-for="CourseId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex align-items-center justify-content-between pt-3 border-top border-secondary">
                            <a class="btn btn-outline-secondary px-4" href="@Url.Action("Index", "Course")">
                                <i class="fas fa-arrow-left me-1"></i> Return to List
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-save me-1"></i> Complete Enrollment
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <!-- Instructions Card -->
            <div class="card mb-4 bg-light shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title text-info fw-bold"><i class="fas fa-info-circle me-1"></i> Instructions</h5>
                    <p class="card-text text-muted small">
                        This tool allows you to link a registered student to an active course.
                    </p>
                    <ul class="text-muted small mb-0">
                        <li>Students must have an active account.</li>
                        <li>Courses must be open for enrollment.</li>
                        <li>The system will prevent duplicate enrollments for the same student-course pair.</li>
                    </ul>
                </div>
            </div>

            <!-- New Section: List of Assigned Courses -->
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-dark text-light border-secondary d-flex justify-content-between align-items-center">
                    <div>
                        <i class="fas fa-list-check me-1 text-info"></i>
                        Recent Assignments
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead class="table-dark sticky-top">
                                <tr class="small text-secondary">
                                    <th class="ps-3">Student</th>
                                    <th>Course</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Note: Ensure 'Enrollments' is added to your EnrollmentViewModel -->
                                @if (Model.Enrollments != null && Model.Enrollments.Any())
                                {
                                    foreach (var assignment in Model.Enrollments)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold">@assignment.StudentName</td>
                                            <td><span class="badge bg-secondary">@assignment.CourseName</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-4 text-muted small italic">
                                            <i class="fas fa-folder-open d-block mb-2 fa-2x opacity-50"></i>
                                            No recent assignments found.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}