@model IEnumerable<SIMS.DatabaseContext.Entities.Course>

@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewData["title"] = "Courses";
    ViewData["breadcrumb"] = "Course Catalog";
    ViewData["breadcrumb-item"] = "Courses";
}

<div class="card mb-4 bg-dark text-light border-secondary shadow">
    <div class="card-header border-secondary d-flex justify-content-between align-items-center">
        <div>
            <i class="fas fa-book me-1 text-primary"></i>
            University Course Catalog
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Course" asp-action="Add" class="btn btn-primary btn-sm px-3">
                <i class="fas fa-plus"></i> Add New Course
            </a>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-striped table-bordered text-light mb-0 align-middle">
                <thead>
                    <tr class="text-secondary small">
                        <th class="ps-3">Code</th>
                        <th>Course Name</th>
                        <th class="text-center">Credits</th>
                        <th class="text-center">Capacity</th>
                        <th>Enrolled</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var course in Model)
                        {
                            <tr>
                                <td class="ps-3"><strong>@course.CourseCode</strong></td>
                                <td>@course.CourseName</td>
                                <td class="text-center">@course.Credits</td>
                                <td class="text-center">@course.Capacity</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="me-2 small">@course.Enrolled / @course.Capacity</span>
                                        <div class="progress flex-grow-1" style="height: 4px; max-width: 50px; background-color: rgba(255,255,255,0.1);">
                                            @{
                                                var percentage = course.Capacity > 0 ? (double)course.Enrolled / course.Capacity * 100 : 0;
                                                var barColor = percentage >= 90 ? "bg-danger" : percentage >= 75 ? "bg-warning" : "bg-success";
                                            }
                                            <div class="progress-bar @barColor" style="width: @percentage%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (course.Status == 1 && course.Enrolled < course.Capacity)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-2">Open</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger px-2">Closed / Full</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Details" asp-route-courseCode="@course.CourseCode" class="btn btn-outline-light btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-courseCode="@course.CourseCode" class="btn btn-outline-info btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-courseCode="@course.CourseCode" class="btn btn-outline-danger btn-sm" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted small italic">
                                <i class="fas fa-folder-open d-block mb-2 fa-2x"></i>
                                No courses available in the catalog.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-success-subtle {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .bg-danger-subtle {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.05) !important;
    }

    .btn-group .btn {
        border-radius: 4px;
        margin-left: 2px;
    }
</style>