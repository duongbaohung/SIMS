@model IEnumerable<SIMS.DatabaseContext.Entities.Grade>

@{
    ViewData["Title"] = "Academic Records";
    var isStudent = User.IsInRole("Student");
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Academic Records</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Dashboard")">Dashboard</a></li>
        <li class="breadcrumb-item active">Grades</li>
    </ol>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <i class="fas fa-table me-1"></i>
                @(isStudent ? "My Grades" : "All Academic Records")
            </div>
            @if (!isStudent)
            {
                <a href="@Url.Action("Create", "Grade")" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus me-1"></i> Input New Grade
                </a>
            }
        </div>
        <div class="card-body">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Course</th>
                        @if (!isStudent)
                        {
                            <th>Student (Username)</th>
                        }
                        <th>Score</th>
                        <th>Grade</th>
                        <th>Remarks</th>
                        <th>Date Recorded</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="@(isStudent ? "5" : "6")" class="text-center text-muted">No records found.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@(item.Course?.CourseName ?? "N/A")</td>
                                @if (!isStudent)
                                {
                                    <td>@(item.Student?.Username ?? "Unknown")</td>
                                }
                                <td class="fw-bold">@item.Score</td>
                                <td>
                                    @if (item.Score >= 80)
                                    {
                                        <span class="badge bg-success">A</span>
                                    }
                                    else if (item.Score >= 70)
                                    {
                                        <span class="badge bg-primary">B</span>
                                    }
                                    else if (item.Score >= 60)
                                    {
                                        <span class="badge bg-info">C</span>
                                    }
                                    else if (item.Score >= 50)
                                    {
                                        <span class="badge bg-warning text-dark">D</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">F</span>
                                    }
                                </td>
                                <td>@item.Remarks</td>
                                <td>@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>