@model SIMS.DatabaseContext.Entities.User

@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewData["Title"] = "Delete Student";
    ViewData["breadcrumb"] = "User Management";
    ViewData["breadcrumb-item"] = "Delete Student";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card bg-dark text-light border-danger shadow">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirm Student Removal
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-1 text-danger mb-3">
                            <i class="fas fa-user-slash"></i>
                        </div>
                        <h3 class="fw-bold">Are you sure?</h3>
                        <p class="text-secondary">
                            You are about to permanently delete the profile for <strong class="text-light">@Model.Username</strong>.
                            This action will remove all access and history for this user.
                        </p>
                    </div>

                    <div class="bg-black bg-opacity-25 p-3 rounded border border-secondary mb-4 small">
                        <div class="row mb-2">
                            <div class="col-4 text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">Email:</div>
                            <div class="col-8">@Model.Email</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-4 text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">Phone:</div>
                            <div class="col-8">@(Model.Phone ?? "N/A")</div>
                        </div>
                        <div class="row">
                            <div class="col-4 text-secondary text-uppercase fw-bold" style="font-size: 0.7rem;">Joined:</div>
                            <div class="col-8">@(Model.CreatedAt?.ToString("dd MMM yyyy") ?? "N/A")</div>
                        </div>
                    </div>

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <div class="row g-2">
                            <div class="col-6">
                                <a asp-action="Index" class="btn btn-outline-secondary w-100 py-2">
                                    <i class="fas fa-times me-2"></i>No, Cancel
                                </a>
                            </div>
                            <div class="col-6">
                                <button type="submit" class="btn btn-danger w-100 py-2 fw-bold">
                                    <i class="fas fa-trash-alt me-2"></i>Yes, Delete
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="text-center mt-3">
                <small class="text-muted">
                    <i class="fas fa-info-circle me-1"></i>
                    This record will be permanently purged from the database.
                </small>
            </div>
        </div>
    </div>
</div>

<style>
    .card.border-danger { border-width: 2px; }
    .bg-black.bg-opacity-25 { background-color: rgba(0, 0, 0, 0.25) !important; }
</style>