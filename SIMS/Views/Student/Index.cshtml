@model IEnumerable<SIMS.DatabaseContext.Entities.User>

@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewData["title"] = "Students";
    ViewData["breadcrumb"] = "List of Students";
    ViewData["breadcrumb-item"] = "Students";
}

<div class="card mb-4 bg-dark text-light border-secondary shadow">
    <div class="card-header border-secondary d-flex justify-content-between align-items-center py-3">
        <div>
            <i class="fas fa-users me-1 text-primary"></i>
            Registered Students
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Student" asp-action="Add" class="btn btn-primary btn-sm px-3">
                <i class="fas fa-plus me-1"></i> Add New Student
            </a>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-striped table-bordered text-light mb-0 align-middle">
                <thead>
                    <tr class="text-secondary small">
                        <th class="ps-3" style="width: 80px;">ID</th>
                        <th>Username</th>
                        <th>Email Address</th>
                        <th>Phone</th>
                        <th>Address</th>
                        <th>Joined Date</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var student in Model)
                        {
                            <tr>
                                <td class="ps-3 text-secondary">@student.Id</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-2 bg-primary text-white">
                                            @(!string.IsNullOrEmpty(student.Username) ? student.Username.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        <strong>@student.Username</strong>
                                    </div>
                                </td>
                                <td>@student.Email</td>
                                <td>@(student.Phone ?? "N/A")</td>
                                <td>@(student.Address ?? "N/A")</td>
                                <td>@(student.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                <td class="text-center">
                                    @if (student.Status == 1)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-2">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger px-2">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group" role="group">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-outline-info btn-sm" title="Edit Student">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@student.Id" class="btn btn-outline-danger btn-sm" title="Remove Student">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">No Actions</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted small italic">
                                <i class="fas fa-user-slash d-block mb-2 fa-2x"></i>
                                No students found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-success-subtle {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .bg-danger-subtle {
        background-color: rgba(220, 53, 69, 0.1) !important;
    }

    .avatar-circle {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255,255,255,0.05) !important;
    }

    .btn-group .btn {
        border-radius: 4px;
        margin-left: 2px;
    }
</style>